{
  "name": "instaskeleton",
  "version": "0.1.2",
  "description": "Ultra-light React skeleton loader with zero DOM scanning. Automatic JSX inference, manual schema support, shimmer & pulse animations. Only ~1.65KB gzipped.",
  "license": "MIT",
  "author": {
    "name": "Sounak Das",
    "url": "https://github.com/LittleBoy9"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/LittleBoy9/instaskeleton.git"
  },
  "bugs": {
    "url": "https://github.com/LittleBoy9/instaskeleton/issues"
  },
  "homepage": "https://littleboy9.github.io/instaskeleton/",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/LittleBoy9"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "example:install": "npm --prefix example install",
    "example:dev": "npm run build && npm --prefix example run dev",
    "example:build": "npm run build && npm --prefix example run build"
  },
  "keywords": [
    "skeleton",
    "skeleton-loader",
    "skeleton-loading",
    "skeleton-screen",
    "react",
    "react-skeleton",
    "react-loading",
    "react-placeholder",
    "loading",
    "loading-state",
    "loading-indicator",
    "placeholder",
    "shimmer",
    "shimmer-effect",
    "pulse",
    "animation",
    "ui",
    "component",
    "typescript",
    "zero-dom-scan",
    "lightweight",
    "performance",
    "jsx-inference"
  ],
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "tsup": "^8.1.0",
    "typescript": "^5.6.0"
  }
}
